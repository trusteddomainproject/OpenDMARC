###
### NO user-serviceable parts beyond this point
###

# Query the StaleMARC RBL.  $type is "domain" or "rua"; $key is the value
# to look up.  Returns 1 if the report should be skipped, 0 if it should
# be sent.  On lookup failure we fail open (proceed with sending).
sub stale_skip
{
	my ($type, $key) = @_;

	return 0 unless $stale_check;

	my $endpoint;
	if ($type eq "domain")
	{
		$endpoint = $stale_def_deny ? "checkDomainDefDeny.php" : "checkDomain.php";
	}
	else
	{
		$endpoint = $stale_def_deny ? "checkRuaDefDeny.php" : "checkRua.php";
	}

	# Encode '@' for use in a query string (only special char in addresses).
	(my $enc_key = $key) =~ s/@/%40/g;

	my $url = "$stale_server/$endpoint?key=$enc_key";
	my $resp = HTTP::Tiny->new(timeout => 10)->get($url);

	if ($resp->{status} == 200)
	{
		if ($verbose)
		{
			print STDERR "$progname: StaleMARC: skipping $key (listed)\n";
		}
		return 1;
	}

	# 404 = not listed (send), anything else = lookup failed (fail open).
	if ($verbose >= 2 && $resp->{status} != 404)
	{
		print STDERR "$progname: StaleMARC: lookup for $key returned $resp->{status}; proceeding\n";
	}

	return 0;
}

# Check the in-memory suppression list loaded from the DB.  $address may be
# a full email address or a bare domain; both forms are checked for email
# addresses so either can appear in the suppressions table.
sub db_skip
{
	my ($address) = @_;

	return 0 unless %db_suppress;

	return 1 if exists $db_suppress{lc($address)};

	if ($address =~ /\@(.+)$/)
	{
		return 1 if exists $db_suppress{lc($1)};
	}

	return 0;
}

# Build a VERP envelope sender encoding $rcpt into $sender.
# e.g. postmaster@r.example.com + dmarc@target.com -> postmaster+dmarc=target.com@r.example.com
sub verp_sender
{
	my ($sender, $rcpt) = @_;
	my ($sloc, $sdom) = split(/@/, $sender, 2);
	(my $enc = $rcpt) =~ s/@/=/;
	return "$sloc+$enc\@$sdom";
}

sub usage
{
	print STDERR "$progname: usage: $progname [options]\n";
	print STDERR "\t--day              send yesterday's data\n";
	print STDERR "\t--db-dsn=dsn       full DBI DSN (overrides --dbscheme/--dbhost/--dbname/--dbport)\n";
	print STDERR "\t--dbscheme=scheme  mysql or MariaDB [$def_dbscheme]\n";
	print STDERR "\t--dbhost=host      database host [$def_dbhost]\n";
	print STDERR "\t--dbname=name      database name [$def_dbname]\n";
	print STDERR "\t--dbpasswd=passwd  database password [$def_dbpasswd]\n";
	print STDERR "\t--dbport=port      database port [$def_dbport]\n";
	print STDERR "\t--dbuser=user      database user [$def_dbuser]\n";
	print STDERR "\t--domain=name      force a report for named domain\n";
	print STDERR "\t--forensic         read a pre-formed AFRF report from\n";
	print STDERR "\t                   stdin and send it via SMTP\n";
	print STDERR "\t--help             print help and exit\n";
	print STDERR "\t--interval=secs    report interval [$def_interval]\n";
	print STDERR "\t--keepfiles        keep xml files (in working directory)\n";
	print STDERR "\t--workdir=path     directory for temporary report files [.]\n";
	print STDERR "\t -n                synonym for --test\n";
	print STDERR "\t--nodomain=name    omit a report for named domain\n";
	print STDERR "\t--skipdomains=file list of domains to omit a report for\n";
	print STDERR "\t--noupdate         don't record report transmission\n";
	print STDERR "\t--report-bcc       bcc address for aggregate reports\n";
	print STDERR "\t--report-contact   contact address for report metadata (default: --report-email)\n";
	print STDERR "\t--report-email     envelope/From address for outgoing reports [$repemail]\n";
	print STDERR "\t--report-org       reporting organization [$repdom]\n";
	print STDERR "\t--smtp-password    smtp authentication password\n";
	print STDERR "\t--smtp-port        smtp server port [$smtp_port]\n";
	print STDERR "\t                   (overrides OPENDMARC_SMTPPORT)\n";
	print STDERR "\t--smtp-server      smtp server [$smtp_server]\n";
	print STDERR "\t                   (overrides OPENDMARC_SMTPSERVER)\n";
	print STDERR "\t--smtp-ssl         use SSL/TLS for SMTP connection\n";
	print STDERR "\t--smtp-ssl-ca-file path to CA bundle for SSL certificate verification\n";
	print STDERR "\t--smtp-username    smtp authentication username\n";
	print STDERR "\t--config=file      config file [$configfile]\n";
	print STDERR "\t--stale-check      skip reports to stale RUA/RUF addresses\n";
	print STDERR "\t                   via StaleMARC RBL lookup\n";
	print STDERR "\t--stale-def-deny   treat untested addresses as stale\n";
	print STDERR "\t--stale-server=url StaleMARC API base URL\n";
	print STDERR "\t--test             don't send reports\n";
	print STDERR "\t--verp             use VERP envelope senders so bounces\n";
	print STDERR "\t                   identify the failing recipient\n";
	print STDERR "\t                   (implies --keepfiles --noupdate)\n";
	print STDERR "\t--utc              operate in UTC\n";
	print STDERR "\t--verbose          verbose output\n";
	print STDERR "\t                   (repeat for increased output)\n";
	print STDERR "\t--version          print version and exit\n";
}

# Scan @ARGV for --config before full option parsing so the config file
# path can itself come from the command line.
for (my $i = 0; $i < @ARGV; $i++)
{
	if ($ARGV[$i] =~ /^--config=(.+)$/)
	{
		$configfile = $1;
		splice(@ARGV, $i, 1);
		last;
	}
	elsif ($ARGV[$i] eq '--config' && $i + 1 < @ARGV)
	{
		$configfile = $ARGV[$i + 1];
		splice(@ARGV, $i, 2);
		last;
	}
}

# Load the config file and prepend its values to @ARGV.  Command-line
# arguments therefore always override config file settings.
if (-f $configfile)
{
	my @config_args;

	open(my $cfg, '<', $configfile)
		or die "$progname: can't open $configfile: $!\n";

	while (<$cfg>)
	{
		chomp;
		s/#.*//;
		s/^\s+|\s+$//g;
		next unless length;

		if (/^([\w-]+)\s*=\s*(.*)$/)
		{
			my ($key, $val) = ($1, $2);
			$val =~ s/\s+$//;

			if ($val =~ /^(1|yes|true)$/i)
			{
				push @config_args, "--$key";
			}
			elsif ($val =~ /^(0|no|false)$/i)
			{
				push @config_args, "--no-$key";
			}
			elsif (length($val))
			{
				push @config_args, "--$key=$val";
			}
		}
	}

	close($cfg);
	unshift @ARGV, @config_args;
}

# set locale
setlocale(LC_ALL, 'C');

sub loadskipdomains
{
	die "Could not open domains file $_[1]" unless open FILE,"<",$_[1];
	while (my $line = <FILE>)
	{
		$line =~ s/\s*#.*//;
		$line =~ s/^\s+//;
		$line =~ s/\s+$//;
		push(@skipdomains, $line);
	}
	close FILE;
}

# parse command line arguments
my $opt_retval = &Getopt::Long::GetOptions ('day!' => \$daybound,
                                            'db-dsn=s' => \$db_dsn,
                                            'dbscheme=s' => \$dbscheme,
                                            'dbhost=s' => \$dbhost,
                                            'dbname=s' => \$dbname,
                                            'dbpasswd=s' => \$dbpasswd,
                                            'dbport=s' => \$dbport,
                                            'dbuser=s' => \$dbuser,
                                            'domain=s' => \$forcedomain,
                                            'forensic!' => \$forensic,
                                            'help!' => \$helponly,
                                            'interval=i' => \$interval,
                                            'keepfiles' => \$keepfiles,
                                            'workdir=s' => \$workdir,
                                            'n|test' => \$testmode,
                                            'nodomain=s' => \@skipdomains,
                                            'skipdomains=s' => \&loadskipdomains,
                                            'report-bcc=s' => \$repbcc,
                                            'report-contact=s' => \$repcontact,
                                            'report-email=s' => \$repemail,
                                            'report-org=s' => \$repdom,
                                            'smtp-password=s' => \$smtp_password,
                                            'smtp-port=i' => \$smtp_port,
                                            'smtp-server=s' => \$smtp_server,
                                            'smtp-ssl!' => \$smtp_ssl,
                                            'smtp-ssl-ca-file=s' => \$smtp_ssl_ca_file,
                                            'smtp-username=s' => \$smtp_username,
                                            'stale-check!' => \$stale_check,
                                            'stale-def-deny!' => \$stale_def_deny,
                                            'stale-server=s' => \$stale_server,
                                            'update!' => \$doupdate,
                                            'verp!' => \$verp,
                                            'utc!' => \$use_utc,
                                            'verbose+' => \$verbose,
                                            'version!' => \$showversion,
                                           );

if (!$opt_retval || $helponly)
{
	usage();

	if ($helponly)
	{
		exit(0);
	}
	else
	{
		exit(1);
	}
}

if ($showversion)
{
	print STDOUT "$progname v$version\n";
	exit(0);
}

# apply defaults
if (!defined($dbhost))
{
	if (defined($ENV{'OPENDMARC_DBHOST'}))
	{
		$dbhost = $ENV{'OPENDMARC_DBHOST'};
	}
	else
	{
		$dbhost = $def_dbhost;
	}
}

if (!defined($dbname))
{
	if (defined($ENV{'OPENDMARC_DB'}))
	{
		$dbname = $ENV{'OPENDMARC_DB'};
	}
	else
	{
		$dbname = $def_dbname;
	}
}

if (!defined($dbpasswd))
{
	if (defined($ENV{'OPENDMARC_PASSWORD'}))
	{
		$dbpasswd = $ENV{'OPENDMARC_PASSWORD'};
	}
	else
	{
		$dbpasswd = $def_dbpasswd;
	}
}

if (!defined($dbport))
{
	if (defined($ENV{'OPENDMARC_PORT'}))
	{
		$dbport = $ENV{'OPENDMARC_PORT'};
	}
	else
	{
		$dbport = $def_dbport;
	}
}

if (!defined($dbuser))
{
	if (defined($ENV{'OPENDMARC_USER'}))
	{
		$dbuser = $ENV{'OPENDMARC_USER'};
	}
	else
	{
		$dbuser = $def_dbuser;
	}
}

if ($smtp_server eq '127.0.0.1' && defined($ENV{'OPENDMARC_SMTPSERVER'}))
{
	$smtp_server = $ENV{'OPENDMARC_SMTPSERVER'};
}

if ($smtp_port == 25 && defined($ENV{'OPENDMARC_SMTPPORT'}))
{
	$smtp_port = $ENV{'OPENDMARC_SMTPPORT'};
}

if (defined($interval) && $daybound)
{
	print STDERR "$progname: WARN: --day overrides --interval\n";
}

if (!defined($interval) || $daybound)
{
	$interval = $def_interval;
}

# Test mode requested, don't update last sent and keep xml files
$doupdate  = ($testmode == 1) ? 0 : $doupdate;
$keepfiles = ($testmode == 1) ? 1 : $keepfiles;

if ($verbose)
{
	print STDERR "$progname: started at " . localtime($now) . "\n";
}

###
### Forensic (failure) report mode: read a pre-formed AFRF message from
### stdin and inject it via SMTP, acting as a drop-in replacement for
### "sendmail -t" as the milter's ReportCommand.
###

if ($forensic)
{
	# Slurp the full message from stdin.
	my $message = do { local $/; <STDIN> };

	if (!defined($message) || $message eq "")
	{
		print STDERR "$progname: --forensic: no message on stdin\n";
		exit(1);
	}

	# Split headers from body on the first blank line.
	my ($hdr_block, $body) = split(/\r?\n\r?\n/, $message, 2);

	# Unfold header continuations so each logical header is one string.
	(my $unfolded = $hdr_block) =~ s/\r?\n([ \t]+)/ $1/g;

	# Collect recipient addresses from To:, Cc:, and Bcc: headers.
	my @rcpts;
	for my $line (split(/\r?\n/, $unfolded))
	{
		next unless $line =~ /^(?:To|Cc|Bcc):\s*(.*)/i;
		my $val = $1;

		# Split on commas that are not inside angle brackets or quotes.
		# We need to handle: bare addr, "Name" <addr>, Name <addr>
		my @addrs;
		while ($val =~ /\G\s*(?:"[^"]*"\s*<([^>]+)>|<([^>]+)>|([^,@\s]+@[^,\s]+))\s*,?\s*/g)
		{
			push @addrs, defined($1) ? $1 : defined($2) ? $2 : $3;
		}
		push @rcpts, @addrs;
	}

	if (!@rcpts)
	{
		print STDERR "$progname: --forensic: no recipients found in message headers\n";
		exit(1);
	}

	# StaleMARC check: remove any recipients that are known-stale.
	@rcpts = grep { !stale_skip("rua", $_) } @rcpts;

	if (!@rcpts)
	{
		print STDERR "$progname: --forensic: all recipients suppressed by StaleMARC check\n";
		exit(0);
	}

	if ($testmode)
	{
		print STDERR "$progname: --forensic: would send forensic report to " .
		             join(", ", @rcpts) . "\n";
		exit(0);
	}

	if ($verbose)
	{
		print STDERR "$progname: --forensic: connecting to $smtp_server:$smtp_port\n";
	}

	$smtp = Net::SMTP->new($smtp_server,
	                       'Port' => $smtp_port,
	                       'Hello' => hostfqdn());
	if (!defined($smtp))
	{
		print STDERR "$progname: --forensic: open SMTP server $smtp_server:$smtp_port failed\n";
		exit(1);
	}

	$smtpfail = 0;

	if ($verp)
	{
		# VERP: one transaction per recipient so each gets a unique MAIL FROM.
		for my $rcpt (@rcpts)
		{
			my $ok = $smtp->mail(verp_sender($repemail, $rcpt)) &&
			         $smtp->to($rcpt) &&
			         $smtp->data() &&
			         $smtp->datasend($message) &&
			         $smtp->dataend();
			if ($verbose || !$ok)
			{
				$answer = ${${*$smtp}{'net_cmd_resp'}}[1] || $smtp->message() || 'unknown error';
				chomp($answer);
				my $status = $ok ? "sent" : "failed to send";
				print STDERR "$progname: --forensic: $status forensic report to $rcpt ($answer)\n";
			}
			$smtpfail = 1 if !$ok;
			$smtp->reset();
		}
	}
	else
	{
		if (!$smtp->mail($repemail))
		{
			$smtpfail = 1;
		}
		else
		{
			for my $rcpt (@rcpts)
			{
				if (!$smtp->to($rcpt))
				{
					$smtpfail = 1;
					last;
				}
			}
		}

		if (!$smtpfail)
		{
			if (!$smtp->data() ||
			    !$smtp->datasend($message) ||
			    !$smtp->dataend())
			{
				$smtpfail = 1;
			}
		}

		if ($verbose || $smtpfail)
		{
			$answer = ${${*$smtp}{'net_cmd_resp'}}[1] || $smtp->message() || 'unknown error';
			chomp($answer);
			my $status = $smtpfail ? "failed to send" : "sent";
			print STDERR "$progname: --forensic: $status forensic report to " .
			             join(", ", @rcpts) . " ($answer)\n";
		}

		$smtp->reset();
	}

	$smtp->quit();

	exit($smtpfail ? 1 : 0);
}

my $dbi_dsn;
if (defined($db_dsn))
{
	$dbi_dsn = $db_dsn;
}
else
{
	require "DBD/$dbscheme.pm";
	$dbi_dsn = "DBI:" . $dbscheme . ":database=" . $dbname .
	           ";host=" . $dbhost;
	if ($dbport != $def_dbport) {
	    $dbi_dsn .= ";port=" . $dbport;
	}
}

$dbi_h = DBI->connect($dbi_dsn, $dbuser, $dbpasswd, { PrintError => 0 });
if (!defined($dbi_h))
{
	print STDERR "$progname: unable to connect to database: $DBI::errstr\n";
	exit(1);
}

if ($verbose >= 2)
{
	print STDERR "$progname: connected to database\n";
}

if ($use_utc)
{
	# MySQL-specific: SET TIME_ZONE has no direct equivalent in SQLite or
	# PostgreSQL (use AT TIME ZONE or session configuration instead).
	$dbi_s = $dbi_h->prepare("SET TIME_ZONE='+00:00'");

	if (!$dbi_s->execute())
	{
		print STDERR "$progname: failed to change to UTC: " . $dbi_h->errstr . "\n";
		$dbi_s->finish;
		$dbi_h->disconnect;
		exit(1);
	}
}

#
# Check schema is current
#

$dbi_s = $dbi_h->prepare("SELECT IS_NULLABLE FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_SCHEMA = DATABASE() AND TABLE_NAME = 'requests' AND COLUMN_NAME = 'lastsent'");
if ($dbi_s->execute() && (my $row = $dbi_s->fetchrow_arrayref()))
{
	if ($row->[0] eq 'NO')
	{
		print STDERR "$progname: WARNING: requests.lastsent column is NOT NULL; schema needs upgrading.\n";
		print STDERR "$progname: WARNING: Run: ALTER TABLE requests MODIFY lastsent TIMESTAMP NULL DEFAULT NULL;\n";
	}
}
$dbi_s->finish;

# MySQL-specific: INFORMATION_SCHEMA.COLUMNS is a MySQL/MariaDB/PostgreSQL
# feature.  SQLite equivalent: PRAGMA table_info(tablename).
$dbi_s = $dbi_h->prepare("SELECT IS_NULLABLE FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_SCHEMA = DATABASE() AND TABLE_NAME = 'messages' AND COLUMN_NAME = 'spf_scope'");
if ($dbi_s->execute() && !(my $row = $dbi_s->fetchrow_arrayref()))
{
	print STDERR "$progname: WARNING: messages.spf_scope column is missing; schema needs upgrading.\n";
	print STDERR "$progname: WARNING: Run: ALTER TABLE messages ADD COLUMN spf_scope TINYINT NOT NULL DEFAULT '-1' AFTER spf;\n";
}
$dbi_s->finish;

$dbi_s = $dbi_h->prepare("SELECT IS_NULLABLE FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_SCHEMA = DATABASE() AND TABLE_NAME = 'requests' AND COLUMN_NAME = 'fo'");
if ($dbi_s->execute() && !(my $row = $dbi_s->fetchrow_arrayref()))
{
	print STDERR "$progname: WARNING: requests.fo column is missing; schema needs upgrading.\n";
	print STDERR "$progname: WARNING: Run: ALTER TABLE requests ADD COLUMN fo TINYINT NOT NULL DEFAULT '0' AFTER pct;\n";
}
$dbi_s->finish;

#
#
# Load reporting suppressions from the database.  Fail open if the table
# does not exist yet (e.g. pre-migration installs).
#

{
	my $s = $dbi_h->prepare("SELECT address FROM suppressions");
	if ($s && $s->execute())
	{
		while (my $row = $s->fetchrow_arrayref())
		{
			$db_suppress{lc($row->[0])} = 1;
		}
		$s->finish;

		if ($verbose >= 2)
		{
			print STDERR "$progname: loaded " . scalar(keys %db_suppress) .
			             " suppression(s) from database\n";
		}
	}
	elsif ($verbose >= 2)
	{
		print STDERR "$progname: no suppressions table found; skipping\n";
	}
}

#
# Select domains on which to report
#

if ($verbose >= 2)
{
	print STDERR "$progname: selecting target domains\n";
}

if (defined($forcedomain))
{
	$dbi_s = $dbi_h->prepare("SELECT name FROM domains WHERE name = ?");

	if (!$dbi_s->execute($forcedomain))
	{
		print STDERR "$progname: failed to test for database entry: " . $dbi_h->errstr . "\n";
		$dbi_s->finish;
		$dbi_h->disconnect;
		exit(1);
	}
}
elsif ($daybound)
{
	# MySQL-specific: FROM_UNIXTIME() converts a Unix timestamp to DATETIME.
	# SQLite equivalent: datetime(?, 'unixepoch')
	$dbi_s = $dbi_h->prepare("SELECT domains.name FROM requests JOIN domains ON requests.domain = domains.id WHERE lastsent IS NULL OR DATE(lastsent) < DATE(FROM_UNIXTIME(?))");
	$dbi_s->bind_param(1, $now, {TYPE => SQL_INTEGER});
	if (!$dbi_s->execute())
	{
		print STDERR "$progname: failed to collect domain names: " . $dbi_h->errstr . "\n";
		$dbi_s->finish;
		$dbi_h->disconnect;
		exit(1);
	}
}
else
{
	# MySQL-specific: DATE_SUB(..., INTERVAL ? SECOND) and FROM_UNIXTIME().
	# SQLite equivalent: datetime(?, 'unixepoch', '-' || ? || ' seconds')
	$dbi_s = $dbi_h->prepare("SELECT domains.name FROM requests JOIN domains ON requests.domain = domains.id WHERE lastsent IS NULL OR lastsent <= DATE_SUB(FROM_UNIXTIME(?), INTERVAL ? SECOND)");
	$dbi_s->bind_param(1, $now, {TYPE => SQL_INTEGER});
	$dbi_s->bind_param(2, $interval, {TYPE => SQL_INTEGER});
	if (!$dbi_s->execute())
	{
		print STDERR "$progname: failed to collect domain names: " . $dbi_h->errstr . "\n";
		$dbi_s->finish;
		$dbi_h->disconnect;
		exit(1);
	}
}

$domainset = $dbi_s->fetchall_arrayref([0]);
$dbi_s->finish;

if ($verbose)
{
	print STDERR "$progname: selected " . scalar(@$domainset) . " domain(s)\n";
}

#
# For each domain:
# 	-- extract reporting address
# 	-- extract messages/signatures to report
# 	-- generate and send report
# 	-- update "last sent" timestamp
#

foreach (@$domainset)
{
	$domain = $_->[0];

	if (!defined($domain))
	{
		next;
	}

	if (@skipdomains && grep({$_ eq $domain} @skipdomains) != 0)
	{
		next;
	}

	if (stale_skip("domain", $domain) || db_skip($domain))
	{
		next;
	}

	if ($verbose >= 2)
	{
		print STDERR "$progname: processing $domain\n";
	}

	# extract this domain's reporting parameters
	$dbi_s = $dbi_h->prepare("SELECT id FROM domains WHERE name = ?");
	if (!$dbi_s->execute($domain))
	{
		print STDERR "$progname: can't get ID for domain $domain: " . $dbi_h->errstr . "\n";
		$dbi_s->finish;
		$dbi_h->disconnect;
		exit(1);
	}

	undef $domainid;
	while ($dbi_a = $dbi_s->fetchrow_arrayref())
	{
		if (defined($dbi_a->[0]))
		{
			$domainid = $dbi_a->[0];
		}
	}
	$dbi_s->finish;

	if (!defined($domainid))
	{
		print STDERR "$progname: ID for domain $domain not found\n";
		next;
	}

	# MySQL-specific: UNIX_TIMESTAMP() converts a DATETIME to a Unix timestamp.
	# SQLite equivalent: strftime('%s', lastsent)
	# PostgreSQL equivalent: EXTRACT(EPOCH FROM lastsent)
	$dbi_s = $dbi_h->prepare("SELECT repuri, adkim, aspf, policy, spolicy, pct, fo, UNIX_TIMESTAMP(lastsent) FROM requests WHERE domain = ?");
        $dbi_s->bind_param(1, $domainid, {TYPE => SQL_INTEGER});
	if (!$dbi_s->execute())
	{
		print STDERR "$progname: can't get reporting URI for domain $domain: " . $dbi_h->errstr . "\n";
		$dbi_s->finish;
		$dbi_h->disconnect;
		exit(1);
	}

	undef $repuri;

	while ($dbi_a = $dbi_s->fetchrow_arrayref())
	{
		if (defined($dbi_a->[0]))
		{
			$repuri = $dbi_a->[0];
		}
		if (defined($dbi_a->[1]))
		{
			$adkim = $dbi_a->[1];
		}
		if (defined($dbi_a->[2]))
		{
			$aspf = $dbi_a->[2];
		}
		if (defined($dbi_a->[3]))
		{
			$policy = $dbi_a->[3];
		}
		if (defined($dbi_a->[4]))
		{
			$spolicy = $dbi_a->[4];
		}
		if (defined($dbi_a->[5]))
		{
			$pct = $dbi_a->[5];
		}
		if (defined($dbi_a->[6]))
		{
			$fo = $dbi_a->[6];
		}
		if (defined($dbi_a->[7]))
		{
			$lastsent = $dbi_a->[7];
		}
	}

	$dbi_s->finish;

	if (!defined($repuri) || ("" eq $repuri))
	{
		if ($verbose >= 2)
		{
			print STDERR "$progname: no reporting URI for domain $domain; skipping\n";
		}

		next;
	}

	if ($daybound)
	{
		my ($sec,$min,$hour,$mday,$mon,$year,$wday,$yday,$isdst) = localtime($now - $interval);
		$repstart = timelocal(0, 0, 0, $mday, $mon, $year);
		($sec,$min,$hour,$mday,$mon,$year,$wday,$yday,$isdst) = localtime($now);
		$repend = timelocal(0, 0, 0, $mday, $mon, $year);
	}
	else
	{
		$repstart = $now - $interval;
		$repend = $now;
	}

	# look up the domain where the DMARC record was actually found (RFC 7489
	# appendix C: policy_published.domain is the record's location, not the
	# from domain, which may be a subdomain inheriting from the org domain)
	undef $pdomain;
	$dbi_s = $dbi_h->prepare(q{
	                         SELECT d2.name
	                         FROM messages
	                         JOIN domains d2 ON messages.policy_domain = d2.id
	                         WHERE messages.from_domain = ?
	                           AND messages.date > FROM_UNIXTIME(?)
	                           AND messages.date <= FROM_UNIXTIME(?)
	                         LIMIT 1
	});
	$dbi_s->bind_param(1, $domainid, {TYPE => SQL_INTEGER});
	$dbi_s->bind_param(2, $repstart, {TYPE => SQL_INTEGER});
	$dbi_s->bind_param(3, $repend,   {TYPE => SQL_INTEGER});
	if ($dbi_s->execute())
	{
		if ($dbi_a = $dbi_s->fetchrow_arrayref())
		{
			$pdomain = $dbi_a->[0] if defined($dbi_a->[0]);
		}
	}
	$dbi_s->finish;
	$pdomain = $domain unless defined($pdomain);

	# construct the temporary file
	$repfile = $workdir . "/" . $repdom . "!" . $domain . "!" . $repstart . "!" . $repend . ".xml";
	$gzipfile = $workdir . "/" . $repdom . "!" . $domain . "!" . $repstart . "!" . $repend . ".xml.gz";
	if (!open($tmpout, ">", $repfile))
	{
		print STDERR "$progname: can't create report file for domain $domain: $!\n";
		next;
	}

	if    ($adkim == ord("r")) { $adkimstr = "r"; }
	elsif ($adkim == ord("s")) { $adkimstr = "s"; }
	else                       { $adkimstr = "unknown"; }

	if    ($aspf == ord("r")) { $aspfstr = "r"; }
	elsif ($aspf == ord("s")) { $aspfstr = "s"; }
	else                      { $aspfstr = "unknown"; }

	if    ($policy == ord("n")) { $policystr = "none"; }
	elsif ($policy == ord("q")) { $policystr = "quarantine"; }
	elsif ($policy == ord("r")) { $policystr = "reject"; }
	else                        { $policystr = "unknown"; }

	if    ($spolicy == 0)        { $spolicystr = $policystr; }
	elsif ($spolicy == ord("n")) { $spolicystr = "none"; }
	elsif ($spolicy == ord("q")) { $spolicystr = "quarantine"; }
	elsif ($spolicy == ord("r")) { $spolicystr = "reject"; }
	else                         { $spolicystr = "unknown"; }

	{
		my @fo_values;
		if (!defined($fo) || $fo == 0)
		{
			$fostr = "0";
		}
		else
		{
			push @fo_values, "0" if ($fo & 0x1);
			push @fo_values, "1" if ($fo & 0x2);
			push @fo_values, "d" if ($fo & 0x4);
			push @fo_values, "s" if ($fo & 0x8);
			$fostr = @fo_values ? join(":", @fo_values) : "0";
		}
	}

	print $tmpout "<?xml version=\"1.0\" encoding=\"UTF-8\" ?>\n";
	print $tmpout "<feedback>\n";
	print $tmpout "    <version>1</version>\n";

	print $tmpout "    <report_metadata>\n";
	print $tmpout "        <org_name>$repdom</org_name>\n";
	print $tmpout "         <email>" . (defined($repcontact) ? $repcontact : $repemail) . "</email>\n";
	print $tmpout "         <report_id>$domain:$now</report_id>\n";
	print $tmpout "         <date_range>\n";
	print $tmpout "         <begin>$repstart</begin>\n";
	print $tmpout "         <end>$repend</end>\n";
	print $tmpout "         </date_range>\n";
	print $tmpout "    </report_metadata>\n";

	print $tmpout "    <policy_published>\n";
	print $tmpout "        <domain>$pdomain</domain>\n";
	print $tmpout "        <adkim>$adkimstr</adkim>\n";
	print $tmpout "        <aspf>$aspfstr</aspf>\n";
	print $tmpout "        <p>$policystr</p>\n";
	print $tmpout "        <sp>$spolicystr</sp>\n";
	print $tmpout "        <pct>$pct</pct>\n";
	print $tmpout "        <fo>$fostr</fo>\n";
	print $tmpout "    </policy_published>\n";

	# MySQL-specific: FROM_UNIXTIME() in both queries below.
	# SQLite equivalent: datetime(?, 'unixepoch')
	if ($daybound)
	{
		$dbi_s = $dbi_h->prepare(q{
		                         SELECT messages.id, ipaddr.addr, messages.disp, d1.name, d2.name,
		                                 messages.spf, messages.spf_scope, messages.align_spf, messages.align_dkim,
		                                 messages.arc, messages.arc_policy
		                         FROM messages
		                         JOIN ipaddr ON messages.ip = ipaddr.id
		                         JOIN domains d1 ON messages.from_domain = d1.id
		                         JOIN domains d2 ON messages.env_domain = d2.id
		                         WHERE messages.from_domain = ?
		                                 AND messages.date >= FROM_UNIXTIME(?)
		                                 AND messages.date < FROM_UNIXTIME(?)
		});
	}
	else
	{
		$dbi_s = $dbi_h->prepare(q{
		                         SELECT messages.id, ipaddr.addr, messages.disp, d1.name, d2.name,
		                                 messages.spf, messages.spf_scope, messages.align_spf, messages.align_dkim,
		                                 messages.arc, messages.arc_policy
		                         FROM messages
		                         JOIN ipaddr ON messages.ip = ipaddr.id
		                         JOIN domains d1 ON messages.from_domain = d1.id
		                         JOIN domains d2 ON messages.env_domain = d2.id
		                         WHERE messages.from_domain = ?
		                                 AND messages.date > FROM_UNIXTIME(?)
		                                 AND messages.date <= FROM_UNIXTIME(?)
		});
	}

        $dbi_s->bind_param(1, $domainid, {TYPE => SQL_INTEGER});
        $dbi_s->bind_param(2, $repstart, {TYPE => SQL_INTEGER});
        $dbi_s->bind_param(3, $repend, {TYPE => SQL_INTEGER});
	if (!$dbi_s->execute())
	{
		print STDERR "$progname: can't extract report for domain $domain: " . $dbi_h->errstr . "\n";
		$dbi_s->finish;
		$dbi_h->disconnect;
		exit(1);
	}

	$rowcount = 0;

	my %groups;
	my @group_order;

	while ($dbi_a = $dbi_s->fetchrow_arrayref())
	{
		undef $msgid;

		if (defined($dbi_a->[0]))
		{
			$msgid = $dbi_a->[0];
		}
		if (defined($dbi_a->[1]))
		{
			$ipaddr = $dbi_a->[1];
		}
		if (defined($dbi_a->[2]))
		{
			$disp = $dbi_a->[2];
		}
		if (defined($dbi_a->[3]))
		{
			$fromdomain = $dbi_a->[3];
		}
		if (defined($dbi_a->[4]))
		{
			$envdomain = $dbi_a->[4];
		}
		if (defined($dbi_a->[5]))
		{
			$spfresult = $dbi_a->[5];
		}
		if (defined($dbi_a->[6]))
		{
			$spf_scope = $dbi_a->[6];
		}
		if (defined($dbi_a->[7]))
		{
			$align_spf = $dbi_a->[7];
		}
		if (defined($dbi_a->[8]))
		{
			$align_dkim = $dbi_a->[8];
		}
		if (defined($dbi_a->[9]))
		{
			$arc = $dbi_a->[9];
		}
		if (defined($dbi_a->[10]))
		{
			$arcpolicy = $dbi_a->[10];
		}

		if (!defined($msgid))
		{
			next;
		}

		$rowcount++;

		my $grpkey = join("\0", $ipaddr     // "",
		                        $disp       // -1,
		                        $align_dkim // -1,
		                        $align_spf  // -1,
		                        $spfresult  // -1,
		                        $spf_scope  // -1,
		                        $fromdomain // "",
		                        $envdomain  // "",
		                        $arc        // -1,
		                        $arcpolicy  // -1);

		if (!exists $groups{$grpkey})
		{
			push @group_order, $grpkey;

			if    ($disp == 0) { $dispstr = "reject"; }
			elsif ($disp == 1) { $dispstr = "reject"; }
			elsif ($disp == 2) { $dispstr = "none"; }
			elsif ($disp == 4) { $dispstr = "quarantine"; }
			else               { $dispstr = "unknown"; }

			if    ($spfresult ==  0) { $spfresultstr = "pass"; }
			elsif ($spfresult ==  2) { $spfresultstr = "softfail"; }
			elsif ($spfresult ==  3) { $spfresultstr = "neutral"; }
			elsif ($spfresult ==  4) { $spfresultstr = "temperror"; }
			elsif ($spfresult ==  5) { $spfresultstr = "permerror"; }
			elsif ($spfresult ==  6) { $spfresultstr = "none"; }
			elsif ($spfresult ==  7) { $spfresultstr = "fail"; }
			elsif ($spfresult ==  8) { $spfresultstr = "policy"; }
			elsif ($spfresult ==  9) { $spfresultstr = "nxdomain"; }
			elsif ($spfresult == 10) { $spfresultstr = "signed"; }
			elsif ($spfresult == 12) { $spfresultstr = "discard"; }
			else                     { $spfresultstr = "unknown"; }

			if    ($align_dkim == 4) { $align_dkimstr = "pass"; }
			elsif ($align_dkim == 5) { $align_dkimstr = "fail"; }
			else                     { $align_dkimstr = "unknown"; }

			if    ($align_spf == 4) { $align_spfstr = "pass"; }
			elsif ($align_spf == 5) { $align_spfstr = "fail"; }
			else                    { $align_spfstr = "unknown"; }

			if ($arcpolicy == 0) { $arcpolicystr = "pass"; }
			else                 { $arcpolicystr = "fail"; }

			if (!defined($spf_scope) || $spf_scope == 2)
			{
				$spf_scopestr = "helo";
			}
			else
			{
				$spf_scopestr = "mfrom";
			}

			# retrieve arc_policy seals for the first message in this group
			$dbi_s2 = $dbi_h->prepare(q{
			                          SELECT arcseals.instance, domains.name AS domain,
			                                 selectors.name AS selector,
			                                 arcauthresults.arc_client_addr as client_ip
			                          FROM arcseals
			                          JOIN domains on arcseals.domain = domains.id
			                          JOIN selectors on arcseals.selector = selectors.id
			                          JOIN arcauthresults on arcseals.message = arcauthresults.message
			                          	AND arcseals.instance = arcauthresults.instance
			                          WHERE arcseals.message = ?
			                          ORDER BY arcseals.instance DESC
			});
			$dbi_s2->bind_param(1, $msgid, {TYPE => SQL_INTEGER});
			if (!$dbi_s2->execute())
			{
				print STDERR "$progname: can't extract report for message $msgid: " . $dbi_h->errstr . "\n";
				$dbi_s2->finish;
				$dbi_s->finish;
				$dbi_h->disconnect;
				exit(1);
			}

			my $arc_policy_output = "arc=$arcpolicystr";
			while ($dbi_hash = $dbi_s2->fetchrow_hashref())
			{
				$arc_policy_output .= " as[$dbi_hash->{instance}].d=$dbi_hash->{domain}";
				$arc_policy_output .= " as[$dbi_hash->{instance}].s=$dbi_hash->{selector}";
				if ($dbi_hash->{instance} == 1 &&
				    defined($dbi_hash->{client_ip}) && $dbi_hash->{client_ip} ne "")
				{
					$arc_policy_output .= " client-ip[$dbi_hash->{instance}]=$dbi_hash->{client_ip}";
				}
			}
			$dbi_s2->finish;

			$groups{$grpkey} = {
				count             => 0,
				ipaddr            => $ipaddr,
				dispstr           => $dispstr,
				align_dkimstr     => $align_dkimstr,
				align_spfstr      => $align_spfstr,
				arc_policy_output => $arc_policy_output,
				fromdomain        => $fromdomain,
				envdomain         => $envdomain,
				spf_scopestr      => $spf_scopestr,
				spfresultstr      => $spfresultstr,
				dkim              => {},
			};
		}

		$groups{$grpkey}{count}++;

		# accumulate DKIM signatures for this message into the group
		$dbi_s2 = $dbi_h->prepare(q{
		                          SELECT domains.name, selectors.name, pass
		                          FROM signatures
		                          JOIN domains ON signatures.domain = domains.id
		                          LEFT JOIN selectors ON signatures.selector = selectors.id
		                          WHERE signatures.message = ?
		});
		$dbi_s2->bind_param(1, $msgid, {TYPE => SQL_INTEGER});
		if (!$dbi_s2->execute())
		{
			print STDERR "$progname: can't extract report for message $msgid: " . $dbi_h->errstr . "\n";
			$dbi_s2->finish;
			$dbi_s->finish;
			$dbi_h->disconnect;
			exit(1);
		}

		while ($dbi_a = $dbi_s2->fetchrow_arrayref())
		{
			next if !defined($dbi_a->[0]);
			my $dk_domain   = $dbi_a->[0];
			my $dk_selector = defined($dbi_a->[1]) ? $dbi_a->[1] : "";
			my $dk_result   = $dbi_a->[2];
			$groups{$grpkey}{dkim}{$dk_domain}{$dk_selector}{$dk_result} = 1
				if defined($dk_result);
		}

		$dbi_s2->finish;
	}

	$dbi_s->finish;

	for my $grpkey (@group_order)
	{
		my $g = $groups{$grpkey};

		print $tmpout "    <record>\n";
		print $tmpout "        <row>\n";
		print $tmpout "            <source_ip>$g->{ipaddr}</source_ip>\n";
		print $tmpout "            <count>$g->{count}</count>\n";
		print $tmpout "            <policy_evaluated>\n";
		print $tmpout "                <disposition>$g->{dispstr}</disposition>\n";
		print $tmpout "                <dkim>$g->{align_dkimstr}</dkim>\n";
		print $tmpout "                <spf>$g->{align_spfstr}</spf>\n";
		print $tmpout "                <reason>\n";
		print $tmpout "                    <type>local_policy</type>\n";
		print $tmpout "                    <comment>$g->{arc_policy_output}</comment>\n";
		print $tmpout "                </reason>\n";
		print $tmpout "            </policy_evaluated>\n";
		print $tmpout "        </row>\n";
		print $tmpout "        <identifiers>\n";
		if (defined($g->{envdomain}) && $g->{envdomain} ne "")
		{
			print $tmpout "            <envelope_from>$g->{envdomain}</envelope_from>\n";
		}
		print $tmpout "            <header_from>$g->{fromdomain}</header_from>\n";
		print $tmpout "        </identifiers>\n";

		print $tmpout "        <auth_results>\n";
		print $tmpout "            <spf>\n";
		print $tmpout "                <domain>$g->{envdomain}</domain>\n";
		print $tmpout "                <scope>$g->{spf_scopestr}</scope>\n";
		print $tmpout "                <result>$g->{spfresultstr}</result>\n";
		print $tmpout "            </spf>\n";

		for my $dk_domain (sort keys %{$g->{dkim}})
		{
			for my $dk_selector (sort keys %{$g->{dkim}{$dk_domain}})
			{
				for my $dk_result (sort keys %{$g->{dkim}{$dk_domain}{$dk_selector}})
				{
					if    ($dk_result ==  0) { $dkimresultstr = "pass"; }
					elsif ($dk_result ==  2) { $dkimresultstr = "softfail"; }
					elsif ($dk_result ==  3) { $dkimresultstr = "neutral"; }
					elsif ($dk_result ==  4) { $dkimresultstr = "temperror"; }
					elsif ($dk_result ==  5) { $dkimresultstr = "permerror"; }
					elsif ($dk_result ==  6) { $dkimresultstr = "none"; }
					elsif ($dk_result ==  7) { $dkimresultstr = "fail"; }
					elsif ($dk_result ==  8) { $dkimresultstr = "policy"; }
					elsif ($dk_result ==  9) { $dkimresultstr = "nxdomain"; }
					elsif ($dk_result == 10) { $dkimresultstr = "signed"; }
					elsif ($dk_result == 12) { $dkimresultstr = "discard"; }
					else                     { $dkimresultstr = "unknown"; }

					print $tmpout "            <dkim>\n";
					print $tmpout "                <domain>$dk_domain</domain>\n";
					print $tmpout "                <selector>$dk_selector</selector>\n";
					print $tmpout "                <result>$dkimresultstr</result>\n";
					print $tmpout "            </dkim>\n";
				}
			}
		}

		print $tmpout "        </auth_results>\n";
		print $tmpout "    </record>\n";
	}

	print $tmpout "</feedback>\n";

	close($tmpout);

	if ($rowcount == 0)
	{
		if ($verbose >= 2)
		{
			print STDERR "$progname: no activity selected for $domain; skipping\n";
		}

		unlink($repfile);
		next;
	}

	# gzip the report
	if (!gzip [ $repfile ] => $gzipfile)
	{
		print STDERR "$progname: can't gzip report for domain $domain: $!\n";
		next;
	}

	if ($keepfiles)
	{
		print STDERR "$progname: keeping report file \"$repfile\"\n";
	}

	# decode the URI
	@repuris = split(',', $repuri);

	for $repuri (@repuris)
	{
		$uri = URI->new($repuri);
		if (!defined($uri) ||
		    !defined($uri->scheme) ||
		    $uri->opaque eq "")
		{
			print STDERR "$progname: can't parse reporting URI for domain $domain\n";
			next;
		}

		$repdest = $uri->opaque;
		my $report_maxbytes = $report_maxbytes_global;

		# check for max report size
		if ($repdest =~ m/^(\S+)!(\d{1,15})([kmgt])?$/i)
		{
			$repdest = $1;
			$report_maxbytes = $2;
			if ($3)
			{
				my $letter = lc($3);
				if ($letter eq 'k')
				{
					$report_maxbytes = $report_maxbytes * 1024;
				}
				if ($letter eq 'm')
				{
					$report_maxbytes = $report_maxbytes * 1048576;
				}
				if ($letter eq 'g')
				{
					$report_maxbytes = $report_maxbytes * (2**30);
				}
				if ($letter eq 't')
				{
					$report_maxbytes = $report_maxbytes * (2**40);
				}
			}
		}

		# Skip if this RUA address is known-stale or locally suppressed.
		if ($uri->scheme eq "mailto" &&
		    (stale_skip("rua", $repdest) || db_skip($repdest)))
		{
			next;
		}

		# Test mode, just report what would have been done
		if ($testmode)
		{
			my $verb = ($uri->scheme eq "mailto") ? "email" : "post";
			print STDERR "$progname: would $verb $domain report for " .
			             "$rowcount records to " . $uri->opaque . "\n";
		}
		# ensure a scheme is present
		elsif (!defined($uri->scheme))
		{
			if ($verbose >= 2)
			{
				print STDERR "$progname: unknown URI scheme in '$repuri' for domain $domain\n";
			}
			next;
		}
		# send/post report
		elsif ($uri->scheme eq "mailto")
		{
			my $datestr;
			my $report_id;

			if (!open($zipin, $gzipfile))
			{
				print STDERR "$progname: can't read gzipped report for $domain: $!\n";
				next;
			}

			$boundary = "report_section";

 			$report_id = $domain . "-" . $now . "@" . $repdom;
			$datestr = strftime("%a, %e %b %Y %H:%M:%S %z (%Z)",
			                    localtime);

			$mailout  = "To: $repdest\n";
			$mailout .= "Bcc: $repbcc\n" if defined($repbcc);
			$mailout .= "From: $repemail\n";
			$mailout .= "Subject: Report Domain: " . $domain . " Submitter: " . $repdom . " Report-ID: " . $report_id . "\n";
			$mailout .= "X-Mailer: " . $progname . " v" . $version ."\n";
			$mailout .= "Date: " . $datestr . "\n";
			$mailout .= "Message-ID: <$report_id>\n";
			$mailout .= "Auto-Submitted: auto-generated\n";
			$mailout .= "MIME-Version: 1.0\n";
			$mailout .= "Content-Type: multipart/mixed; boundary=\"$boundary\"\n";
			$mailout .= "\n";
			$mailout .= "This is a MIME-encapsulated message.\n";
			$mailout .= "\n";
			$mailout .= "--$boundary\n";
			$mailout .= "Content-Type: text/plain;\n";
			$mailout .= "\n";
			$mailout .= "This is a DMARC aggregate report for $domain\n";
			$mailout .= "generated at " . localtime() . "\n";
			$mailout .= "\n";
			$mailout .= "--$boundary\n";
			$mailout .= "Content-Type: application/gzip\n";
			$mailout .= "Content-Disposition: attachment; filename=\"$gzipfile\"\n";
			$mailout .= "Content-Transfer-Encoding: base64\n";
			$mailout .= "\n";

			while (read($zipin, $buf, 60*57))
			{
				$mailout .= encode_base64($buf);
			}

			$mailout .= "\n";
			$mailout .= "--$boundary--\n";
			my $reportsize = length($mailout);

			if ($reportsize > $report_maxbytes)
			{
				# XXX -- generate an error report here
				print STDERR "$progname: report was too large ($reportsize bytes) per limitation of URI " . $uri->opaque . " for domain $domain\n";
			}
			else
			{
				$smtpstatus = "sent";
				$smtpfail = 0;

				if (!defined($smtp))
				{
					$smtp = Net::SMTP->new($smtp_server,
					                       'Port'    => $smtp_port,
					                       'Hello'   => hostfqdn(),
					                       'SSL'     => $smtp_ssl,
					                       defined($smtp_ssl_ca_file) ? ('SSL_ca_file' => $smtp_ssl_ca_file) : ());
					if (!defined($smtp))
					{
						print STDERR "$progname: open SMTP server $smtp_server:$smtp_port failed\n";
						exit(1);
					}

					if (defined($smtp_username) && defined($smtp_password))
					{
						if (!$smtp->auth($smtp_username, $smtp_password))
						{
							print STDERR "$progname: SMTP authentication failed\n";
							exit(1);
						}
					}
				}

				my $mailfrom = $verp ? verp_sender($repemail, $repdest) : $repemail;
				if (!$smtp->mail($mailfrom) ||
				    !$smtp->to($repdest) ||
				    (defined($repbcc) && !$smtp->to($repbcc)) ||
				    !$smtp->data() ||
				    !$smtp->datasend($mailout) ||
				    !$smtp->dataend())
				{
					$smtpfail = 1;
					$smtpstatus = "failed to send";
				}

				if ($verbose || $smtpfail)
				{
					# now perl voodoo:
					$answer = ${${*$smtp}{'net_cmd_resp'}}[1] || $smtp->message() || 'unknown error';
					chomp($answer);
					print STDERR "$progname: $smtpstatus report for $domain to $repdest ($answer)\n";
				}
			}

			$smtp->reset();

			close($zipin);
		}
		elsif ($uri->scheme eq "http" || $uri->scheme eq "https")
		{
			if (!open($zipin, $gzipfile))
			{
				print STDERR "$progname: can't read zipped report for $domain: $!\n";
				next;
			}

			my $zipdata;
			{
				local $/;
				$zipdata = <$zipin>;
			}
			close($zipin);

			my $reportsize = length($zipdata);
			if ($reportsize > $report_maxbytes)
			{
				print STDERR "$progname: report was too large ($reportsize bytes) per limitation of URI " . $uri->opaque . " for domain $domain\n";
				next;
			}

			my $req = HTTP::Request->new(POST => $repuri);
			$req->content_type('application/gzip');
			$req->content($zipdata);

			my $ua = LWP::UserAgent->new;
			$ua->agent("$progname/$version");
			my $resp = $ua->request($req);

			if ($resp->is_success)
			{
				if ($verbose)
				{
					print STDERR "$progname: posted report for $domain to $repuri (" . $resp->status_line . ")\n";
				}
			}
			else
			{
				print STDERR "$progname: failed to post report for $domain to $repuri (" . $resp->status_line . ")\n";
			}
		}
		else
		{
			print STDERR "$progname: unsupported reporting URI scheme " . $uri->scheme . " for domain $domain\n";
			next;
		}
	}

	# update "last sent" timestamp
	if ($doupdate)
	{
		# MySQL-specific: FROM_UNIXTIME() converts a Unix timestamp to DATETIME.
		# SQLite equivalent: datetime(?, 'unixepoch')
		$dbi_s = $dbi_h->prepare("UPDATE requests SET lastsent = FROM_UNIXTIME(?) WHERE domain = ?");
                $dbi_s->bind_param(1, $repend, {TYPE => SQL_INTEGER});
                $dbi_s->bind_param(2, $domainid, {TYPE => SQL_INTEGER});
		if (!$dbi_s->execute())
		{
			print STDERR "$progname: can't update last sent time for domain $domain: " . $dbi_h->errstr . "\n";
			$dbi_s->finish;
			$dbi_h->disconnect;
			exit(1);
		}
	}

	unlink($gzipfile);
	if (!$keepfiles)
	{
		unlink($repfile);
	}
}

$smtp->quit() if defined($smtp);

#
# all done!
#

$dbi_s->finish;

if ($verbose)
{
	print STDERR "$progname: terminating at " . localtime() . " (duration=" . scalar(time() - $now) . "s)\n";
}

$dbi_h->disconnect;

exit(0);
