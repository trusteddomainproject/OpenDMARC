# DB parameters
my $def_dbscheme  = "@SQL_BACKEND@";
my $def_dbhost    = "localhost";
my $def_dbname    = "opendmarc";
my $def_dbuser    = "opendmarc";
my $def_dbpasswd  = "opendmarc";
