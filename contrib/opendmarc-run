#
# Wrapper script to rotate the opendmarc history file, import it, expire
# old records, and send aggregate reports.  Intended to be run from cron.

HISTFILE=/var/db/opendmarc/opendmarc.dat
IMPORTFILE=${HISTFILE}.import

IMPORT=/usr/local/sbin/opendmarc-import
EXPIRE=/usr/local/sbin/opendmarc-expire
REPORTS=/usr/local/sbin/opendmarc-reports

DBHOST=localhost
DBUSER=opendmarc
DBPASSWD=opendmarc
DBSCHEME=mysql
WORKDIR=/var/db/opendmarc

# Set DOMAIN to restrict reporting to a single domain, or leave empty to
# report for all domains with data in the database.
DOMAIN=

# SMTP authentication.  Leave SMTPUSER and SMTPPASSWD empty for unauthenticated
# submission (the default, suitable for a local MTA on 127.0.0.1:25).
# Set SMTPSSL=--smtp-ssl when connecting to a server that requires SSL/TLS.
# Set SMTPCAFILE to the path of a CA bundle for servers using a private or
# self-signed certificate.  Leave empty to use the system CA bundle.
SMTPUSER=
SMTPPASSWD=
SMTPSSL=
SMTPCAFILE=

DBOPTS="--dbhost=${DBHOST} --dbuser=${DBUSER} --dbpasswd=${DBPASSWD} --dbscheme=${DBSCHEME}"

# Rotate the history file atomically before importing so that opendmarc
# can immediately start writing new records while we process the old ones.
if [ -s "${HISTFILE}" ]; then
	mv "${HISTFILE}" "${IMPORTFILE}" && \
	    ${IMPORT} ${DBOPTS} --input="${IMPORTFILE}" && \
	    rm "${IMPORTFILE}"
fi

${EXPIRE} ${DBOPTS}

${REPORTS} ${DBOPTS} ${DOMAIN:+--domain ${DOMAIN}} --workdir ${WORKDIR} \
    ${SMTPUSER:+--smtp-username ${SMTPUSER}} \
    ${SMTPPASSWD:+--smtp-password ${SMTPPASSWD}} \
    ${SMTPSSL} \
    ${SMTPCAFILE:+--smtp-ssl-ca-file ${SMTPCAFILE}}
